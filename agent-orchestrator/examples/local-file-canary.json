{
  "schema_version": 1,
  "id": "local-ministral-file-canary",
  "objective": "Read instructions.md and create the requested result.txt exactly.",
  "target_dir": "agent-orchestrator/examples/file-canary",
  "mode": "write",
  "importance": "low",
  "risk": "low",
  "tool_class": "files_write",
  "required_capabilities": ["file-editing"],
  "context": ["instructions.md"],
  "expected_artifacts": ["result.txt"],
  "verifiers": [
    {
      "id": "exact-content",
      "argv": ["{python}", "-c", "from pathlib import Path; raise SystemExit(0 if Path('result.txt').read_text(encoding='utf-8') == 'FILE_ONLY_CANARY_PASS\\n' else 1)"],
      "timeout_seconds": 10
    }
  ],
  "dependencies": [],
  "model_profile": "local-ministral-files",
  "limits": {"timeout_seconds": 240, "max_turns": 4, "max_tokens": 4000}
}
