{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-learn.local/schemas/orchestrator-job-v1.json",
  "title": "AI-Learn orchestrator job",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "objective", "target_dir", "mode", "importance", "risk", "tool_class"],
  "properties": {
    "schema_version": {"const": 1},
    "id": {"type": "string", "minLength": 1},
    "objective": {"type": "string", "minLength": 1},
    "target_dir": {"type": "string", "minLength": 1},
    "mode": {"enum": ["read", "write"]},
    "importance": {"enum": ["critical", "high", "normal", "low"]},
    "risk": {"enum": ["critical", "high", "medium", "low"]},
    "tool_class": {"enum": ["inference", "files_read", "files_write", "commands"]},
    "required_capabilities": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "context": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "expected_artifacts": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "dependencies": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "model_profile": {"type": "string"},
    "output_schema": {"type": "string"},
    "allowed_commands": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "python -m unittest -v",
          "python -m pytest -q",
          "pytest -q",
          "npm test",
          "npm run lint",
          "npm run typecheck",
          "npm run build",
          "git diff --",
          "git status --short",
          "git add",
          "git add .",
          "git commit -m",
          "git status"
        ]
      }
    },
    "allowed_write_paths": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "verifiers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "argv"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "argv": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 3600}
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timeout_seconds": {"type": "integer", "minimum": 1},
        "max_turns": {"type": "integer", "minimum": 1},
        "max_tokens": {"type": "integer", "minimum": 1},
        "max_output_tokens": {"type": "integer", "minimum": 1}
      }
    },
    "materialization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "operation", "template"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "operation": {"enum": ["append", "write"]},
        "template": {"type": "string", "minLength": 1}
      }
    }
  }
}
