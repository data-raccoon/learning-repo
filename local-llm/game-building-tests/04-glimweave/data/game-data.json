  "constants": {
    "baseFadeTime": 10000,
    "baseDriftSpeed": 120,
    "baseReservoirCapacity": 100,
    "maxMotes": 500,
    "offline": {
      "maxSeconds": 3600,
      "productionMultiplier": 0.5
    },
    "retuning": {
      "iridescenceFormula": "floor(totalGlimCapturedThisRun / 200) + 1",
      "minimumIntervalBase": 300,
      "diminishingReturnsThreshold": 10
    },
    "victory": {
      "requirements": [
        "phase === 4",
        "ownedClassCount === 5",
        "reservoir === maxCapacity for 60 continuous seconds",
        "totalGlimCaptured >= 10000",
        "upgrades.purchased >= 12"
      ],
      "scoreFormula": "floor(totalGlimCaptured * (1 + iridescence / 100) * (1 + doctrineBonus))",
      "doctrineBonus": {
        "Luminance": 0,
        "Captivation": 0.05,
        "Resilience": 0.1
      }
    },
    "tutorial": {
      "steps": 8
    }
  }
